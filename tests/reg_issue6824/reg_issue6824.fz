#  Source code of Fuzion test reg_issue6824
#
# -----------------------------------------------------------------------

reg_issue6824 =>

  my_choice : choice unit nil is
  my_choice2 : my_choice is

  test1(x T) =>
    if T : my_choice
      say "$T is my_choice {type_of x} $x"
    else
      say "$T is not my_choice"

  test1 (id my_choice unit)
  test1 (id my_choice nil)
  test1 (id my_choice2 unit)
  test1 (id my_choice2 nil)


  my_type : Any is
  my_type2 : my_type is

  test2(x T) =>
    if T : my_type
      say "$T is my_type {type_of x} $x"
    else
      say "$T is not not my_type"

  test2 my_type
  test2 my_type2
