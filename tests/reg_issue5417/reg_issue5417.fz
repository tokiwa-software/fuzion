ex is
  a is
  ex is
    b is
    ex is
      c is
      inner (d universe.ex.ex.this,
            e ex.ex.ex.this,
            f ex.this,               # 1. should flag an error: Ambiguous type
            g ex.ex.this) is         # 2. should flag an error: Ambiguous type
        _ := d.b
        _ := d.c                      # 3. should flag an error: Could not find called feature
        _ := e.b                      # 4. should flag an error: Could not find called feature
        _ := e.c
        _ := f.b                      # These should not flag an error since type is ambiguous already.
        _ := f.c                      # These should not flag an error since type is ambiguous already.
        _ := g.b                      # These should not flag an error since type is ambiguous already.
        _ := g.c                      # These should not flag an error since type is ambiguous already.
