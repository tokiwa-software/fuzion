open_type_parameter_args =>

  a(A type, B type...) : choice A B is

  c a i32 String bool := "hello"

  match c
    i32 =>  panic ""
    str String => say str
    bool => panic ""

  d a i32 String := "world"

  match d
    i32 => panic ""
    str String => say str
