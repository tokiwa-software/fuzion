C ref is
  tail l => abstract

l : choice nil C is
  red =>
    say "hi"
    match l.this
      nil =>
      c C => c.tail.red

l1 => (_ : C is redef tail l := nil)
l2 l => (_ : C is redef tail l := l1)

l2.red
