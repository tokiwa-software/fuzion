lib_container_array3 is

  mutate ! ()->
    a := mutate.new_array3 i32 2 3 4 0

    a[0,1,1] := 7
    a[1,0,0] := 3
    a[1,2,3] := 5
    

    say a[0,1,1]
    say a[1,0,0]

    a[1,0,0] := 12354

    say a[1,0,0]
    say a.as_array
