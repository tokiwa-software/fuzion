Cs ref is
  tail l => abstract

S ref is
  al l => abstract
  red =>
    say "hi"
    match al
      nil    =>
      c Cs => c.tail.red

l : choice nil Cs, S is
  redef al => l.this

l1 l :=
  id l (_ : Cs is
          public redef tail l := nil)
s1 S => l1
l2 S =>
  id l (_ : Cs is
          public redef tail l := l1)

l2.red
