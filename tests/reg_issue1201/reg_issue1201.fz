demo1_unit_types is
  Monoid (T type) ref is
    zero T => abstract
    add (a, b T) T => abstract

  accum (T type, a array T, m demo1_unit_types.this.Monoid T) T =>
    for
      res := m.zero, m.add res x
      x in a
    else
      res

  sum : demo1_unit_types.this.Monoid i32 is
    redef zero => 0
    redef add (a, b i32) => a + b

  product : demo1_unit_types.this.Monoid i32 is
    redef zero => 1
    redef add (a, b i32) => a * b

  i32array     := [ 23, 345 , 3, 1, 3 ]
  totalSum     := accum i32 i32array sum
  totalProduct := accum i32 i32array product

  say i32array
  say totalSum
  say totalProduct
