# Test that verifies mutate effects behave correctly when used in multiple
# threads.
#
# This test uses `container.Ring_Buffer` as example code that requires a
# mutate effect, but it also contains some specific tests for `mutate.array`,
# `mutate.array2`, and `mutate.array3`.
#
ring_buf =>

  expect(thread String,
         expect option X,
         got    option X)
  =>
    say "$thread expecting $(($expect).pad 7) $(($got).pad 7) $(expect = got ? "" : "*** FAIL ***")"


  # try a thread-local local mutate
  #
  lm : mutate is

  lm ! ()->
    rb := container.Ring_Buffer String lm 3

    # add and poll elements including poll on empty and add on full:
    expect "t0" nil     (rb.poll           )    # poll on empty ring buffer []        -> []
    expect "t0" true    (rb.add "A"        )    # add first element         []        -> [A]
    expect "t0" "A"     (rb.poll           )    # poll only element         [A]       -> []
    expect "t0" nil     (rb.poll           )    # poll on empty ring buffer []        -> []
    expect "t0" true    (rb.add "B"        )    # add first element         []        -> [B]
    expect "t0" true    (rb.add "C"        )    # add second element        [B]       -> [B,C]
    expect "t0" true    (rb.add "D"        )    # add third element         [B,C]     -> [B,C,D]
    expect "t0" "B"     (rb.poll           )    # poll on three elements    [B,C,D]   -> [C,D]
    expect "t0" "C"     (rb.poll           )    # poll on two elements      [C,D]     -> [D]
    expect "t0" true    (rb.add "E"        )    # add second element        [D]       -> [D,E]
    expect "t0" true    (rb.add "F"        )    # add third element         [D,E]     -> [D,E,F]
    expect "t0" false   (rb.add "G"        )    # add to full ring          [D,E,F]   -> [D,E,F]
    expect "t0" "D"     (rb.poll           )    # poll on three elements    [D,E,F]   -> [E,F]
    expect "t0" "E"     (rb.poll           )    # poll on two elements      [E,F]     -> [F]
    expect "t0" "F"     (rb.poll           )    # poll on one element       [F]       -> []
    expect "t0" nil     (rb.poll           )    # poll on empty ring buffer []        -> []
    expect "t0" true    (rb.add "H"        )    # add first element         []        -> [H]

    # Now try to poll from another thread, which is expected to fail:
    t1 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          say <| "t1: " + rb.poll + "*** FAILED! NOT ALLOWED in other thread!";
        .catch m->
          if $m = "(precondition, safety: is_this_mutate_instated_and_usable)"
            say "OK, expected fault: $m"
          else
            say "*** FAILED! $m"

    t1.join

    say <| "t0: expecting H       got: " + rb.take               # take on one element       [H]       -> []
    fuzion.runtime.fault
      .try ()->
        say <| "t0: " + rb.take + "*** FAILED! BLOCKING in single thread"   # poll on empty ring buffer []        -> []
      .catch m->
        exp := ("*** panic ***",
                "mutate.wait on '(container.Ring_Buffer String ring_buf.lm).take.(λ(()-> !is_empty0))' would wait forever")
        expect "t0" exp m


    # testing mutable arrays from another thread

    my_array1 := lm.new_array 256 _->(i64 42)
    my_array1[192] := 99
    my_array2 := lm.new_array2 16 16 (u8 67)
    my_array2[08,15] := 99
    my_array3 := lm.new_array3 4 4 4 (i16 -32000)
    my_array3[1,2,3] := 4711

    ta := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          say <| "ta: " + my_array1[ 67] + "*** FAILED! NOT ALLOWED in other thread!";
          say <| "ta: " + my_array1[192] + "*** FAILED! NOT ALLOWED in other thread!";
          my_array1[192] := -9999999999999
          say <| "ta: " + my_array1[ 67] + "*** FAILED! NOT ALLOWED in other thread!";
          say <| "ta: " + my_array1[192] + "*** FAILED! NOT ALLOWED in other thread!";
        .catch m->
          if $m = "(precondition, safety: is_accessible)"
            say "OK, expected fault: $m"
          else
            say "*** FAILED! $m"
      fuzion.runtime.fault
        .try ()->
          my_array2[08,15] := 55
          say <| "ta: " + my_array2[ 6, 7] + "*** FAILED! NOT ALLOWED in other thread!";
          say <| "ta: " + my_array2[08,15] + "*** FAILED! NOT ALLOWED in other thread!";
          my_array2[08,15] := 255
          say <| "ta: " + my_array2[ 6, 7] + "*** FAILED! NOT ALLOWED in other thread!";
          say <| "ta: " + my_array2[08,15] + "*** FAILED! NOT ALLOWED in other thread!";
        .catch m->
          if $m = "(precondition, safety: is_accessible)"
            say "OK, expected fault: $m"
          else
            say "*** FAILED! $m"
      fuzion.runtime.fault
        .try ()->
          say <| "ta: " + my_array3[0,1,2] + "*** FAILED! NOT ALLOWED in other thread!";
          say <| "ta: " + my_array3[1,2,3] + "*** FAILED! NOT ALLOWED in other thread!";
          my_array3[1,2,3] := 303
          say <| "ta: " + my_array3[0,1,2] + "*** FAILED! NOT ALLOWED in other thread!";
          say <| "ta: " + my_array3[1,2,3] + "*** FAILED! NOT ALLOWED in other thread!";
        .catch m->
          if $m = "(precondition, safety: is_accessible)"
            say "OK, expected fault: $m"
          else
            say "*** FAILED! $m"

    ta.join


  # test blocking_mutate that can be used in several threads:

  bm : concur.blocking_mutate is

  bm ! ()->
    rb := container.Ring_Buffer String bm 3

    # add and poll elements including poll on empty and add on full:
    expect "t0" nil     (rb.poll           )    # poll on empty ring buffer []        -> []
    expect "t0" true    (rb.add "A"        )    # add first element         []        -> [A]
    expect "t0" "A"     (rb.poll           )    # poll only element         [A]       -> []
    expect "t0" nil     (rb.poll           )    # poll on empty ring buffer []        -> []
    expect "t0" true    (rb.add "B"        )    # add first element         []        -> [B]
    expect "t0" true    (rb.add "C"        )    # add second element        [B]       -> [B,C]
    expect "t0" true    (rb.add "D"        )    # add third element         [B,C]     -> [B,C,D]
    expect "t0" "B"     (rb.poll           )    # poll on three elements    [B,C,D]   -> [C,D]
    expect "t0" "C"     (rb.poll           )    # poll on two elements      [C,D]     -> [D]
    expect "t0" true    (rb.add "E"        )    # add second element        [D]       -> [D,E]
    expect "t0" true    (rb.add "F"        )    # add third element         [D,E]     -> [D,E,F]
    expect "t0" false   (rb.add "G"        )    # add to full ring          [D,E,F]   -> [D,E,F]
    expect "t0" "D"     (rb.poll           )    # poll on three elements    [D,E,F]   -> [E,F]
    expect "t0" "E"     (rb.poll           )    # poll on two elements      [E,F]     -> [F]
    expect "t0" "F"     (rb.poll           )    # poll on one element       [F]       -> []
    expect "t0" nil     (rb.poll           )    # poll on empty ring buffer []        -> []
    expect "t0" true    (rb.add "H"        )    # add first element         []        -> [H]

    # Now try to poll from another thread
    t2 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          expect "t2" "H"     (rb.poll           )    # poll on one element       [H]     -> []
          expect "t2" true    (rb.add "I"        )    # add first element         []      -> [I]
          expect "t2" true    (rb.add "J"        )    # add second element        [I]     -> [I,J]
          expect "t2" true    (rb.add "K"        )    # add fhird element         [I,J]   -> [I,J,K]
          expect "t2" false   (rb.add "L"        )    # add to full ring          [I,J,K] -> [I,J,K]
          expect "t2" "I"     (rb.poll           )    # poll on three elements    [I,J,K] -> [J,K]
        .catch m->
          say "*** FAILED! $m"

    t2.join

    # Now try to poll from yet another thread
    t3 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          expect "t3" "J"     (rb.poll           )    # poll on two elements      [J,K]   -> [K]
          expect "t3" true    (rb.add "M"        )    # add second element        [K]     -> [K,M]
          expect "t3" true    (rb.add "N"        )    # add second element        [K]     -> [K,M,N]
          expect "t3" "K"     (rb.poll           )    # poll on two elements      [K,M]   -> [M]
        .catch m->
          say "*** FAILED! $m"

    # busy wait for `M` to be first
    do until rb.peek.or_else "" = "M"
    rm := rb.poll                               # poll on one/two elems     [M]/[M,N] -> []/[N]

    # busy wait for `N` to be first
    do until rb.peek.or_else "" = "N"
    rn := rb.poll                               # poll on one element       [N]       -> []
    rnl := rb.poll                              # poll on empty ring buffer []        -> []

    t3.join

    # output results after `t3.join` to avoid races with `t3` during output:
    expect "t0" "M"     (rm                )    # poll on one/two elems     [M]/[M,N] -> []/[N]
    expect "t0" "N"     (rn                )    # poll on one element       [N]       -> []
    expect "t0" nil     (rnl               )    # poll on empty ring buffer []        -> []

    # Now try to poll from yet another thread
    t4 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          expect "t4" true    (rb.add "O"        )    # add second element        []     -> [O]
          expect "t4" true    (rb.add "P"        )    # add second element        [O]    -> [O,P]
          time.Nano.env.sleep (time.duration.ms 100)
          expect "t4" true    (rb.add "Q"        )    # add second element        [O,P]  -> [O,P,Q]
          expect "t4" unit    (rb.put "R"        )    # add second element        [..,Q] -> [..,Q,R]
          expect "t4" unit    (rb.put "S"        )    # add second element        [..,R] -> [..,R,S]
          expect "t4" unit    (rb.put "T"        )    # add second element        [..,S] -> [..,S,T]
          expect "t4" unit    (rb.put "U"        )    # add second element        [..,T] -> [..,T,U]
        .catch m->
          say "*** FAILED! $m"

    ro := rb.take               # blocking take from ring_buffer [O?,P?,Q?] -> [P?,Q?]
    rp := rb.take               # blocking take from ring_buffer [P?,Q?]    -> [Q?]
    rq := rb.take               # blocking take from ring_buffer [Q?]       -> []
    time.Nano.env.sleep (time.duration.ms 100)
    rr := rb.take               # blocking take from ring_buffer [R?,..]    -> [S?,..]
    rs := rb.take               # blocking take from ring_buffer [S?,..]    -> [T?,..]
    rt := rb.take               # blocking take from ring_buffer [T?,..]    -> [U?]
    ru := rb.take               # blocking take from ring_buffer [U?,..]    -> []
    rn2:= rb.poll               # poll on empty ring buffer      []         -> []

    t4.join

    # output results after `t4.join` to avoid races with `t3` during output:
    expect "t0" "O"     (ro           )    # blocking take from ring_buffer [O?,P?,Q?] -> [P?,Q?]
    expect "t0" "P"     (rp           )    # blocking take from ring_buffer [P?,Q?]    -> [Q?]
    expect "t0" "Q"     (rq           )    # blocking take from ring_buffer [Q?]       -> []
    expect "t0" "R"     (rr           )    # blocking take from ring_buffer [R?,..]    -> [S?,..]
    expect "t0" "S"     (rs           )    # blocking take from ring_buffer [S?,..]    -> [T?,..]
    expect "t0" "T"     (rt           )    # blocking take from ring_buffer [T?,..]    -> [U?]
    expect "t0" "U"     (ru           )    # blocking take from ring_buffer [U?,..]    -> []
    expect "t0" nil     (rn2          )    # poll on empty ring buffer      []         -> []

    # testing mutable arrays from another thread

    my_array1 := bm.env.new_array 256 _->(i64 42)
    my_array2 := bm.env.new_array2 16 16 (u8 67)
    my_array3 := bm.env.new_array3 4 4 4 (i16 -32000)
    bm.env.exclusive ()->
      my_array1[192] := 99
      my_array2[08,15] := 99
      my_array3[1,2,3] := 4711

    tb := concur.Threads.env.spawn ()->
      bm.env.exclusive ()->
        fuzion.runtime.fault
          .try ()->
            expect "tb" (i64 42) my_array1[ 67]
            expect "tb" (i64 99) my_array1[192]
            my_array1[192] := -9999999999999
            expect "tb" (i64 42) my_array1[ 67]
            expect "tb" (i64 -9999999999999) my_array1[192]
          .catch m->
            say "*** FAILED! $m"
        fuzion.runtime.fault
          .try ()->
            expect "tb" (u8  67) my_array2[ 6, 7]
            expect "tb" (u8  99) my_array2[08,15]
            my_array2[08,15] := 255
            expect "tb" (u8  67) my_array2[ 6, 7]
            expect "tb" (u8 255) my_array2[08,15]
          .catch m->
            say "*** FAILED! $m"
        fuzion.runtime.fault
          .try ()->
            expect "tb" (i16 -32000) my_array3[0,1,2]
            expect "tb" (i16   4711) my_array3[1,2,3]
            my_array3[1,2,3] := 303
            expect "tb" (i16 -32000) my_array3[0,1,2]
            expect "tb" (i16    303) my_array3[1,2,3]
          .catch m->
            say "*** FAILED! $m"

    tb.join

    # now test using three consumer threads t5, t6, t7 that are fed by one
    # producer thread (current thread):

    t5 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          for x := rb.take until x = "QUIT"
        .catch m->
          say "*** FAILED! $m"
    t6 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          for x := rb.take until x = "QUIT"
        .catch m->
          say "*** FAILED! $m"
    t7 := concur.Threads.env.spawn ()->
      fuzion.runtime.fault
        .try ()->
          for x := rb.take until x = "QUIT"
        .catch m->
          say "*** FAILED! $m"

    for i in 1..10 do

      # give the threads some time to start or empty the buffer:
      time.Nano.env.sleep (time.duration.ms 10)

      # push 5000 entries to the ring buffer
      for j in 1..5000 do
        rb.put "X"

    # tell all threads to stop
    rb.put "QUIT"
    rb.put "QUIT"
    rb.put "QUIT"

    t5.join
    t6.join
    t7.join


  # NYI: UNDER DEVELOPMENT: More tests to be added with blocking operations!
