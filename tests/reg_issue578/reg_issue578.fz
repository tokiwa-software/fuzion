reg_issue578 =>

  nom is
    parser ref is
      parse(i i32) i32 => abstract

    c(arg parser) : parser is
      redef parse(i i32) i32 =>
        arg.parse i

  ex : nom =>

    my_parser : parser is
      redef parse(n i32) i32 =>
        1
    c my_parser

  ex
