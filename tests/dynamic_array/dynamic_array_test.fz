#
#  Source code of Fuzion test dynamic_array_test
#
# -----------------------------------------------------------------------

dynamic_array_test =>

  m : mutate is
  m ! ()->

    da := container.Dynamic_Array m i32 .empty

    check da.can_add
    check da.max_capacity.is_nil

    for i in 1..10 do
      da.add i
      check da.length = i.as_i64

    da.add_all 11..20
    check da.length = 20

    for i in da.indices do
      da[i] := da[i] * 2

    for i in (1..20).reverse do
      check da.remove_last = i*2
      check da.length = i.as_i64-1
