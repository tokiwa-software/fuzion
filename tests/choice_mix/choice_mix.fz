choice_mix is

  Nil is
  MyObj ref is
  MyRef(x,y,z i32) ref : MyObj is
    _ i32 := x+x
    _ i32 := y+y
    _ i32 := z+z

  Mix : choice i32
               bool
               String
               Nil
               MyRef is

  a Mix := 3
  b Mix := true
  c Mix := "string"
  d Mix := Nil
  e Mix := MyRef 3 4 5

  show_a =>
    yap "show_a "
    match a
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  show_v =>
    yap "show_v "
    match a
      i i32    => say "i32:    $i"
      b1 bool  => say "bool:   $b1"
      s String => say "string: $s"
      n Nil    => say "Nil:    $n"
      m MyRef  => say "MyRef:  $m"

  show_i =>
    yap "show_a "
    match a
      i32, String, Nil => say "has 'i'"
      bool, MyRef      => say "has no 'i'"

  show_b =>
    yap "show_b  "
    match b
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  show_c =>
    yap "show_c  "
    match c
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  show_d =>
    yap "show_d  "
    match d
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  show_e =>
    yap "show_e  "
    match e
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  v00 Mix := 42

  show00 =>
    yap "show00 "
    match v00
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  show0(v Mix) =>
    yap "show0  "
    match v
      i32    => say "i32:    "
      bool   => say "bool:   "
      String => say "string: "
      Nil    => say "Nil:    "
      MyRef  => say "MyRef:  "

  show(v Mix) =>
    yap "show   "
    match v
      i i32    => say "i32:    $i"
      b1 bool  => say "bool:   $b1"
      s String => say "string: $s"
      n Nil    => say "Nil:    $n"
      m MyRef  => say "MyRef:  $m"

  yap "a: "; show_a
  yap "b: "; show_b
  yap "c: "; show_c
  yap "d: "; show_d
  yap "e: "; show_e

  yap "a: "; set v00 := a; show00
  yap "b: "; set v00 := b; show00
  yap "c: "; set v00 := c; show00
  yap "d: "; set v00 := d; show00
  yap "e: "; set v00 := e; show00

  yap "a: "; show0 a
  yap "b: "; show0 b
  yap "c: "; show0 c
  yap "d: "; show0 d
  yap "e: "; show0 e

  for
    i := 0, i + 1
  while i < 6
    if i > 0 say "-------------"
    yap "show_a : "; show_a
    yap "show_v : "; show_v
    yap "show_i : "; show_i
    yap "show a: "; show a
    yap "show b: "; show b
    yap "show c: "; show c
    yap "show d: "; show d
    x Mix := a
    set a := b
    set b := c
    set c := d
    set d := e
    set e := x

  colors1 unit =>  # using choice over features inheriting from abstract feature
    color is rgb u32 => abstract
    red     : color is redef rgb => u32 255 * 256 * 256
    green   : color is redef rgb => u32 255 * 256
    blue    : color is redef rgb => u32 255
    yellow  : color is redef rgb => red.rgb + green.rgb
    magenta : color is redef rgb => red.rgb + blue.rgb
    black   : color is redef rgb => u32 0
    white   : color is redef rgb => red.rgb + blue.rgb + green.rgb
    transparent (alpha u32) : color
      pre alpha ≥ u32 0; alpha ≤ u32 255
    is
      redef rgb => alpha * 256*256*256

    p choice red
             green
             blue
             yellow
             magenta
             black
             white
             transparent := red
    q choice red
             green
             blue
             yellow
             magenta
             black
             white
             transparent := red
    r choice red
             green
             blue
             yellow
             magenta
             black
             white
             transparent := red
    s choice red
             green
             blue
             yellow
             magenta
             black
             white
             transparent := red
    t choice red
             green
             blue
             yellow
             magenta
             black
             white
             transparent := red

    print(c1 choice red
                   green
                   blue
                   yellow
                   magenta
                   black
                   white
                   transparent) unit
    =>
      match c1
        re red         => say "red $(re.rgb)"
        g green        => say "grn $(g.rgb)"
        bl blue        => say "blu $(bl.rgb)"
        y yellow       => say "yel $(y.rgb)"
        m magenta      => say "mag $(m.rgb)"
        k black        => say "blk $(k.rgb)"
        w white        => say "wht $(w.rgb)"
        tr transparent => say "trp $(tr.rgb)"

    set p := red
    set q := green
    set r := black
    set s := transparent 200
    set t := transparent 100
    print p
    print q
    print r
    print s
    print t
  colors1

  colors2 unit => # same as colors1, using pipe notation
    color is rgb u32 => abstract
    red     : color is redef rgb => u32 255 * 256 * 256
    green   : color is redef rgb => u32 255 * 256
    blue    : color is redef rgb => u32 255
    yellow  : color is redef rgb => red.rgb + green.rgb
    magenta : color is redef rgb => red.rgb + blue.rgb
    black   : color is redef rgb => u32 0
    white   : color is redef rgb => red.rgb + blue.rgb + green.rgb
    transparent (alpha u32) : color
      pre alpha ≥ u32 0; alpha ≤ u32 255
    is
      redef rgb => alpha * 256*256*256

    p red
      | green
      | blue
      | yellow
      | magenta
      | black
      | white
      | transparent := red
    q red
      | green
      | blue
      | yellow
      | magenta
      | black
      | white
      | transparent := red
    r red
      | green
      | blue
      | yellow
      | magenta
      | black
      | white
      | transparent := red
    s red
      | green
      | blue
      | yellow
      | magenta
      | black
      | white
      | transparent := red
    t red
      | green
      | blue
      | yellow
      | magenta
      | black
      | white
      | transparent := red

    print(c1 red
          | green
          | blue
          | yellow
          | magenta
          | black
          | white
          | transparent) unit
    =>
      match c1
        re red         => say "red$(re.rgb)"
        g green        => say "grn$(g.rgb)"
        bl blue        => say "blu$(bl.rgb)"
        y yellow       => say "yel$(y.rgb)"
        m magenta      => say "mag$(m.rgb)"
        k black        => say "blk$(k.rgb)"
        w white        => say "wht$(w.rgb)"
        tr transparent => say "trp$(tr.rgb)"
    set p := red
    set q := green
    set r := black
    set s := transparent 200
    set t := transparent 100
    print p
    print q
    print r
    print s
    print t
  colors2

  alternatives1 unit => # use pipe for choice result type
    f(i i32) i32 | bool | String =>
      if i < 10 { i }
      else if i < 20 { i > 15 }
      else { "Large" }
    for
      i := 0, i + 1
    while i < 25
      yap "$i ==> "
      match f i
        x i32    => yap x
        b1 bool  => { if b1 { yap  "true" } else { yap "false" } }
        s String => yap s
      say ""

    # check that pipe also works as operator:
    (1..10).for_each yap
    say ""
  alternatives1

  alternatives2 unit => # use pipe for choice argument type
    Nil2 is
    MyRef2 (a,b,c i32) ref is

    test(p i32 | bool | String | Nil2 | MyRef2) unit =>
      match p
        i i32    => say "i32:    $i"
        b1 bool  => say "bool:   $b1"
        s String => say "string: $s"
        n Nil2   => say "Nil:    $n"
        m MyRef2 => say "MyRef:  $m"

    test 3
    test true
    test "string"
    test Nil2
    test (MyRef2 3 4 5)
  alternatives2
