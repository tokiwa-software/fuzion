reg_issue6397 =>

  # problem was the **error** type was shown in error message
  #
  #     actual type found   : '**error**'
  #     assignable to       : '**error**'
  #

  public concat (T type, B type..., values B...) Sequence T =>
    values.typed_foldf [] U,e,v->
      res Sequence T =>
        if U : T
          e.concat [v]
        else if U : Sequence T
          e.concat v
        else
          compile_time_panic
      res
