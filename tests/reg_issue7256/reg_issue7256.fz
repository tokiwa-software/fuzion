public my_mut : mutate is

  public abstract_a (public T type) ref is

  public arr (public T type) ref : abstract_a T is
    public type.empty abstract_a T =>
      my_mut.this.env.arr T

foo is
  m : my_mut is
  m ! ()->
    say <| (m.arr path).empty

  a(M type : m, mm M) =>
    mm ! ()->
      say <| (M.arr path).empty
  a m

foo2 : foo is

_ := foo2
