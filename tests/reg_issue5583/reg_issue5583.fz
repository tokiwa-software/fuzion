has_me is
  type.me has_me.this => abstract

a : has_me is
  fixed redef type.me a => a
  b : has_me is
    fixed redef type.me => a.this.me.b

q : a is
  fixed redef type.me q => q

v := q.b.type.me
say (type_of v)
say v

test(T type : has_me) =>
  w := T.me
  say (type_of w)
  say w

test a.b
test q.b

