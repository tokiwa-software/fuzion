reg_issue5592 =>
  f is
    g(U type : f.this) =>
      say U

    # NYI: BUG: #6762 parser bug: No line break may occur at this position
    # h(U type)
    #   pre U : f.this
    # =>
    #   say U

    i(U type)
    =>
      if U : f.this
        say U
      else
        say "constraint not satisfied"

    # constraint must not be choice
    # j(U type : option f.this) =>
    #   say U

    k(U type)
      pre U : (Sequence f.this)->f.this
    =>
      say U

    l(U type)
    =>
      if U : (f.this, array f.this)
        say U
      else
        say "constraint not satisfied"

  f.g f
  # f.h f
  f.i f
  # f.j f
  f.k (Sequence f)->f
  f.l (f, array f)


  ff : f is

  ff.g ff
  # f.h f
  # does not satisfy the constraint
  ff.i f
  # while this does
  ff.i ff
  # f.j f
  ff.k (Sequence ff)->ff
  # does not satisfy the constraint
  ff.l (f, array f)
  # while this does
  ff.l (ff, array ff)
