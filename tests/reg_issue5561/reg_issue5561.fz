#
#  Source code of Fuzion test reg_issue5561
#
# -----------------------------------------------------------------------

reg_issue5561 =>

  f1(x i32) =>                  # *** fails ***
    if      x = 1 then "aa"
    else if x = 2 then nil
    else               option "bb"

  f2(x i32) =>
    if      x = 1 then option "bb"
    else if x = 2 then nil
    else               "aa"

  f3(x i32) =>                  # *** fails ***
    if      x = 1 then nil
    else if x = 2 then "aa"
    else               option "bb"

  f4(x i32) =>
    if      x = 1 then nil
    else if x = 2 then option "bb"
    else               "aa"

  g1(x i32) =>                  # *** fails ***
    if      x = 1 then "aa"
    else if x = 2 then nil
    else if x = 3 then option "bb"
    else               Any

  g2(x i32) =>
    if      x = 1 then Any
    else if x = 2 then nil
    else if x = 3 then option "bb"
    else               "aa"

  g3(x i32) =>
    if      x = 1 then option "bb"
    else if x = 2 then nil
    else if x = 3 then "aa"
    else               Any

  h(x i32) =>
    if      x = 1 then "aa"
    else               option "bb"

  # an example the requires boxing

  a : C is
  b : C is
  C ref is
  b1(x i32) =>                  # *** fails ***
    if      x = 1 then a
    else if x = 2 then b
    else               C


  say (f1 envir.args.count)
  say (f2 envir.args.count)
  say (f3 envir.args.count)
  say (f4 envir.args.count)
  say (g1 envir.args.count)
  say (g2 envir.args.count)
  say (g3 envir.args.count)
  say (h envir.args.count)
  say (b1 envir.args.count)
