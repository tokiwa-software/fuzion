#
#  Source code of Fuzion test reg_issue4637
#
# -----------------------------------------------------------------------

# test for diverting ps_maps with shared internal data
#
test_map =>

  # original code from #4637
  #
  e := container.ps_map i32 String .empty
  a := e.put 1 "一"
  b := a.put 2 "二"
  c := b.put 3 "三"
  _ := b.put 4 "四"
  _ := c.put 4 "四"

  # simple test mapping 7 items
  #
  m7 := e.put 1 "一"
         .put 2 "二"
         .put 3 "三"
         .put 4 "四"
         .put 5 "五"
         .put 6 "六"
         .put 7 "七"
  say m7

  # incrementally create maps with up to 10 items with shared internal arrays
  #
  # thse will be used below to create divering maps
  #
  m1          := e         .put 1 "一"
  m12         := m1        .put 2 "二"
  m123        := m12       .put 3 "三"
  m1234       := m123      .put 4 "四"
  m12345      := m1234     .put 5 "五"
  m123456     := m12345    .put 6 "六"
  m1234567    := m123456   .put 7 "七"
  m12345678   := m1234567  .put 8 "八"
  m123456789  := m12345678 .put 9 "九"
  m123456789A := m123456789.put 10 "十"

  # create diversions by adding a larger element
  n1          := m1         .put 12 "十二"
  n12         := m12        .put 12 "十二"
  n123        := m123       .put 12 "十二"
  n1234       := m1234      .put 12 "十二"
  n12345      := m12345     .put 12 "十二"
  n123456     := m123456    .put 12 "十二"
  n1234567    := m1234567   .put 12 "十二"
  n12345678   := m12345678  .put 12 "十二"
  n123456789  := m123456789 .put 12 "十二"
  n123456789A := m123456789A.put 12 "十二"

  say "n1         : $n1"
  say "n12        : $n12"
  say "n123       : $n123"
  say "n1234      : $n1234"
  say "n12345     : $n12345"
  say "n123456    : $n123456"
  say "n1234567   : $n1234567"
  say "n12345678  : $n12345678"
  say "n123456789 : $n123456789"
  say "n123456789A: $n123456789A"

  # create diversions by adding a smaller element
  n01          := m1         .put 0 "ゼロ"
  n012         := m12        .put 0 "ゼロ"
  n0123        := m123       .put 0 "ゼロ"
  n01234       := m1234      .put 0 "ゼロ"
  n012345      := m12345     .put 0 "ゼロ"
  n0123456     := m123456    .put 0 "ゼロ"
  n01234567    := m1234567   .put 0 "ゼロ"
  n012345678   := m12345678  .put 0 "ゼロ"
  n0123456789  := m123456789 .put 0 "ゼロ"
  n0123456789A := m123456789A.put 0 "ゼロ"

  say "n01         : $n01"
  say "n012        : $n012"
  say "n0123       : $n0123"
  say "n01234      : $n01234"
  say "n012345     : $n012345"
  say "n0123456    : $n0123456"
  say "n01234567   : $n01234567"
  say "n012345678  : $n012345678"
  say "n0123456789 : $n0123456789"
  say "n0123456789A: $n0123456789A"

  # create diversion maps of 9 omitting one item
  #
  o23456789A := e        .put 2 "二"
                         .put 3 "三"
                         .put 4 "四"
                         .put 5 "五"
                         .put 6 "六"
                         .put 7 "七"
                         .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o13456789A := m1       .put 3 "三"
                         .put 4 "四"
                         .put 5 "五"
                         .put 6 "六"
                         .put 7 "七"
                         .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o12456789A := m12      .put 4 "四"
                         .put 5 "五"
                         .put 6 "六"
                         .put 7 "七"
                         .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o12356789A := m123     .put 5 "五"
                         .put 6 "六"
                         .put 7 "七"
                         .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o12346789A := m1234    .put 6 "六"
                         .put 7 "七"
                         .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o12345789A := m12345   .put 7 "七"
                         .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o12345689A := m123456  .put 8 "八"
                         .put 9 "九"
                         .put 10 "十"

  o12345679A := m1234567 .put 9 "九"
                         .put 10 "十"

  o12345678A := m12345678.put 10 "十"

  say o23456789A
  say o13456789A
  say o12456789A
  say o12356789A
  say o12346789A
  say o12345789A
  say o12345689A
  say o12345679A
  say o12345678A
  say o12345678A

  # create diversion maps of 10 replacing one item by "何"
  #
  p_23456789A := e        .put 1 "何"
                          .put 2 "二"
                          .put 3 "三"
                          .put 4 "四"
                          .put 5 "五"
                          .put 6 "六"
                          .put 7 "七"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p1_3456789A := m1       .put 2 "何"
                          .put 3 "三"
                          .put 4 "四"
                          .put 5 "五"
                          .put 6 "六"
                          .put 7 "七"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p12_456789A := m12      .put 3 "何"
                          .put 4 "四"
                          .put 5 "五"
                          .put 6 "六"
                          .put 7 "七"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p123_56789A := m123     .put 4 "何"
                          .put 5 "五"
                          .put 6 "六"
                          .put 7 "七"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p1234_6789A := m1234    .put 5 "何"
                          .put 6 "六"
                          .put 7 "七"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p12345_789A := m12345   .put 6 "何"
                          .put 7 "七"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p123456_89A := m123456  .put 7 "何"
                          .put 8 "八"
                          .put 9 "九"
                          .put 10 "十"

  p1234567_9A := m1234567 .put 8 "何"
                          .put 9 "九"
                          .put 10 "十"

  p12345678_A := m12345678.put 9 "何"
                          .put 10 "十"

  p123456789_ := m123456789.put 10 "何"

  say p_23456789A
  say p1_3456789A
  say p12_456789A
  say p123_56789A
  say p1234_6789A
  say p12345_789A
  say p123456_89A
  say p1234567_9A
  say p12345678_A
  say p123456789_
