ex_buffered_writer =>


  lm : mutate is

  wh : (io.buffered lm).Writer is
    public redef writer(b Sequence u8) outcome unit =>
      io.Out.env.write b

  lm ! ()->

    _ := (io.buffered lm).Writer.instate _ wh ()->
      x := array u8 _ 1023 i->0x61
      y := array u8 _ 2049 i->0x62
      z := array u8 _ 128  i->0x63

      _ := (io.buffered lm).Writer.env.write x
      _ := (io.buffered lm).Writer.env.write y
      _ := (io.buffered lm).Writer.env.write z
      _ := (io.buffered lm).Writer.env.flush
