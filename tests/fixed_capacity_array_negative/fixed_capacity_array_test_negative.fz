fixed_capacity_array_test_negative =>


  m : mutate is
  m ! ()->

    fca := container.Fixed_Capacity_Array m i32 .empty 10

    check fca.max_capacity = 10
    check fca.can_add

    for i in 1..10 do
      fca.add i
      check fca.length = i.as_i64


    for i in (1..10).reverse do
      check i = (fca.remove_last)
      check fca.length = i.as_i64-1

    for i in 11..20 do
      fca.add i
      check fca.length = i.as_i64-10

    check !fca.can_add

    fca.add 21 # should panic: Fixed_Capacity_Array can not grow, exceeded limit of 10 elements
