reg_issue6817 =>

  # the type of the or_else is T that is constrainted with bool
  # but it is not possible and should not be possible to assign false
  # which is of type bool

  h (T type, v option T) =>
    if T : bool
      say <| v.or_else false
    else
      compile_time_panic

  h true
