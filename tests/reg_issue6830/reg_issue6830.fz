#  Source code of Fuzion test reg_issue6830
#
# -----------------------------------------------------------------------

reg_issue6830 =>


  part1 =>
    storage(T type, v0 T) is
      m0 := mut v0
      store(v T) =>
        m0 <- v

    Fref ref is
      w(s _ : storage String) =>
        s.store "4711"

    g : Fref is
      redef w(s _ : storage Any) =>
        s.store 67

    test(p Fref) =>
      x := storage String "123"
      p.w x
      _ := x.m0.get.parse_i32

    test Fref
    test g


  part2 =>
    storage(T type, v0 T) is
      m0 := mut v0
      store(v T) =>
        m0 <- v

    f ref is
      w(s _ : storage String) =>
        s.store "4711"

    g : f is
      redef w(s _ : storage Any) =>
        s.store 67

    test(p _ : f) =>
      x := storage String "123"
      p.w x
      _ := x.m0.get.parse_i32

    test f
    test g

