#
#  Source code of Fuzion test concrete_types_in_fixed
#
# -----------------------------------------------------------------------

a is
  d is
  outer a.this => abstract
  with_arg(_ a.this) unit => abstract
  res_d d => abstract

b : a is
  redef fixed outer b.this => abstract
  redef fixed with_arg(_ b.this) unit => abstract
  redef fixed res_d b.this.d => abstract


c is
  a is
    outer c.this => abstract
    with_arg(_ c.this) unit => abstract

  b : c.this.a is
    # this-types that are unrelated to feature we are fixed to are allowed
    redef fixed outer c.this => abstract
    # this-types that are unrelated to feature we are fixed to are allowed
    redef fixed with_arg(_ c.this) unit => abstract

