aa
  (
   T type
  ) : Sequence T is


  # create a list from this array
  #
  public redef as_list list T => slice.as_list


  public slice Sequence T
  =>
    as aa.this


  # create a cons cell for a list of this array starting at the given
  # index `i` and up to `to`
  #
  array_cons(a A : aa T) : Cons T (list T)
  is
    public redef head T => a[0]
    public redef tail list T => a.slice.as_list


as(T type, X type : aa T, data X) : aa T is

  #
  public redef as_list list T =>
    array_cons as.this



say (aa String).slice
