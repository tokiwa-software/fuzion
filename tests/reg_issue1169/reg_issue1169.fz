# from the issue:

# See this example:
# ```
# a is
#   nose is
#     sneeze => say "achoo"
#   infix +(o a) : nose => infix + .this.sneeze
# a + a
# ```
# The space between `+` and `.` is required. It is not possible to write
# ```
#   infix +(o a) : nose => infix +.this.sneeze
# ```
# or
# ```
#   infix +(o a) : nose => (infix +).this.sneeze
# ```
# or
# ```
#   infix +(o a) : nose => infix (+).this.sneeze
# ```
# We might want to allow one of the alternatives using `(`/`)`.

a is
  nose is
    sneeze => say "achoo"
  infix +(o a) : nose => (infix +).this.sneeze
a + a
