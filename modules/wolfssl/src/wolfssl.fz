lm : mutate is


# NYI: UNDER DEVELOPMENT: these are unsupported by fzextract
#
memcpy(dest Native_Ref, src lm.array u8, sz i64) Native_Ref => native


# NYI: UNDER DEVELOPMENT: define effect
public wolfssl(T type, LM type : mutate, LM2 type: mutate, code ()->T) T ! LM, LM2 =>

  c => c lm

  check c.wolfSSL_Init=1
  ctx := c.wolfSSL_CTX_new c.wolfTLSv1_2_client_method
  check !(ffi.is_null ctx)


  my_IORecv : Function i32 Native_Ref Native_Ref i32 Native_Ref is
    public redef call(ssl Native_Ref, buf Native_Ref, sz i32, ctx Native_Ref) i32 =>
      match (io.buffered LM).reader.env.read
        s Sequence =>
          (io.buffered LM).reader.env.discard sz
          x := (min sz s.count)
          lm ! ()->
            _ := memcpy buf (lm.array u8 .from_Sequence s) x.as_i64
          x
        outcome => exit 1


  my_IOSend : Function i32 Native_Ref Native_Ref i32 Native_Ref is
    public redef call(ssl Native_Ref, buf Native_Ref, sz i32, ctx Native_Ref) i32 =>
      arr := ffi.from_native_array u8 buf sz
      (io.buffered LM).writer.env.write arr .or_panic
      (io.buffered LM).writer.env.flush.or_panic
      sz


  c.wolfSSL_CTX_SetIORecv ctx my_IORecv

  c.wolfSSL_CTX_SetIOSend ctx my_IOSend

  /**

  NYI: BUG: does not work yet e.g.: /tests/mod_wolfssl/

  c.wolfSSL_CTX_SetIORecv ctx (ssl, buf, sz, ctx)->
    match (io.buffered LM).reader.env.read
      s Sequence =>
        (io.buffered LM).reader.env.discard sz
        x := (min sz s.count)
        _ := memcpy buf (lm.array u8 .from_Sequence s) x
        x
      outcome => exit 1

  c.wolfSSL_CTX_SetIOSend ctx (ssl, buf, sz, ctx)->
    arr := ffi.from_native_array u8 buf sz
    ((io.buffered LM).writer.env.write arr) .or_panic
    (io.buffered LM).writer.env.flush .or_panic
    sz

  */



  ssl := c.wolfSSL_new ctx
  check !(ffi.is_null ssl)


  wolf_ssl_read_handler : io.Read_Handler is

    public redef read(max_count i32) choice (Sequence u8) io.end_of_file error =>
      read choice (Sequence u8) io.end_of_file error =>
        arr := lm.array u8 .new max_count.as_i64 0
        res := c.wolfSSL_read ssl arr max_count
        if res = -1
          error "error reading from ssl ($res) {c.wolfSSL_get_error ssl res}"
        else if res = 0
          io.end_of_file
        else
          arr.as_array res
      lm ! read


  wolf_ssl_writer_handler : io.Write_Handler is

    public redef write(b Sequence u8) outcome unit =>
      write outcome unit =>
        res := c.wolfSSL_write ssl (lm.array u8 .from_Sequence b) b.count
        if res <= 0
          error "error writing to ssl connection ($res) {c.wolfSSL_get_error ssl res}"
      lm ! write


  r := ((io.buffered LM2).reader wolf_ssl_read_handler) ! ()->
    (io.buffered LM2).writer wolf_ssl_writer_handler ! ()->
      code.call


  c.wolfSSL_free ssl
  c.wolfSSL_CTX_free ctx
  _ := c.wolfSSL_Cleanup

  r
