#  Source code of Fuzion feature sodium
#
# -----------------------------------------------------------------------


lm : mutate is

c => c lm


# NYI: UNDER DEVELOPMENT: not supported by fzextract
module crypto_pwhash_strbytes i64 /* from: unsigned long */ => native
module crypto_pwhash_str(out lm.array u8 /* from: char[128] */, passwd lm.array u8 /* from: char * */, passwdlen u64 /* from: unsigned long long */, opslimit u64 /* from: unsigned long long */, memlimit u64 /* from: unsigned long */) i32 /* from: int */ => native
module crypto_pwhash_opslimit_interactive u64 /* from: unsigned long */ => native
module crypto_pwhash_memlimit_interactive u64 /* from: unsigned long */ => native



# sodium -- unit feature to group libsodium related features
#
public sodium is

  # get a (salted) password hash for password
  #
  public type.password_hash(password String) outcome String =>

    lm ! ()->

      out := lm.array u8 .new password_hash_length 0
      passwd := lm.array u8 .from_Sequence password.utf8

      sodium.sodium_init

      if {
        0 = crypto_pwhash_str
                out
                passwd
                passwd.length.as_u64
                crypto_pwhash_opslimit_interactive
                crypto_pwhash_memlimit_interactive
        }
        String.from out.as_array
      else
        # NYI: UNDER DEVELOPMENT: type inference
        id (outcome String) (error "out of memory (crypto_pwhash)")


  # the length of the password hash that password_hash returns
  #
  public type.password_hash_length i64 => crypto_pwhash_strbytes


  type.sodium_init =>
    res := c.sodium_init
    # 0=success, 1=already initialized
    check res=0 | res=1


  # verify that hash belongs to password
  #
  public type.password_hash_verify(password String, hash String) bool
    pre hash.utf8.count.as_i64 = password_hash_length
  =>

    lm ! ()->

      passwd := lm.array u8 .from_Sequence password.utf8
      hsh := lm.array u8 .from_Sequence hash.utf8

      sodium.sodium_init

      0 = c.crypto_pwhash_str_verify
              hsh
              passwd
              passwd.length.as_u64
