# Abstract_Dynamic_Array -- parent of array implementation like `Dynamic_Array` and `Fixed_Capacity_Array`
#
# This provides basic functionality for adding to and removing from the end of the array
#
module:public Abstract_Dynamic_Array (

  # the mutate effect
  #
  public LM type : mutate,

  # element type
  #
  public T type

) ref : container.Buffer T LM
is


  # add an element at the end of this array
  #
  public add (o T) unit => abstract


  # add an element at the end of this array
  #
  public add_all (s Sequence T) unit =>
    for e in s do add e


  # remove the last element of the this array
  #
  public remove_last option T => abstract
