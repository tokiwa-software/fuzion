module:public Mutable_Priority_Queue(public T type) ref is

  # test_is_fist_or_same(a, b T) bool =>  # FIXME: remove debug code
  #   first_or_same a b

  # test_get_fist_or_same(a, b T) T =>    # FIXME: remove debug code
  #   first_or_same a b ? a : b

  # add an element to the queue
  #
  public enqueue(elem T) unit => abstract

  # iteratively add all element to the queue
  #
  public enqueue_all(elements Sequence T) unit =>
    for e in elements do enqueue e


  # get and remove the element with highest priority
  #
  # this is the element with either minimum or maximum value
  # depending on the chosen queue/comparator
  #
  public dequeue option T => abstract


  # enqueue elem and then dequeue (return and remove) the highest priority element
  #
  public enqueue_dequeue(elem T) T => abstract

  public peek option T => abstract

  public contains(elem T) bool
    pre T : property.equatable
  => abstract

  # Does remove make sense? If so should there be a remove_one and remove_all?
  # public remove(elem T) => abstract



  # Create a new priority queue that returns the smallest element first
  # using natural ordering of the elements
  #
  public type.new_min_first container.Mutable_Priority_Queue T
    pre T : property.orderable
  => abstract

  # Create a new priority queue that returns the largest element first
  # using natural ordering of the elements
  #
  public type.new_max_first container.Mutable_Priority_Queue T
    pre T : property.orderable
  => abstract

  public type.new_max_first_test container.Mutable_Priority_Queue T
    pre T : property.orderable
  => abstract

  public type.new_comp(first_or_same Binary bool T1 T1) container.Mutable_Priority_Queue T1 => abstract
