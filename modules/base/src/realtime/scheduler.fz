# scheduler primitive for realtime tasks
#
public scheduler (s Scheduler_Handler) : effect
is

  # submit a task to the scheduler
  #
  public submit(P type : time.Period, t realtime.task P) unit =>
    s.submit P t


  # stop accepting new tasks for scheduling
  #
  public redef finally unit =>
    s.finally


# Scheduler_Handler -- abstract definition of a scheduler
#
public Scheduler_Handler ref is

  # accept a task for processing
  #
  public submit(P type : time.Period, t realtime.task P) unit => abstract


  # stop accepting new tasks
  #
  public finally unit => abstract
