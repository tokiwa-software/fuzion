# effect for configuring the default buffer size
# used by buffered.reader/writer
#
public Buffer_Size ref : effect is

  public get i64
  post
    debug: result > 0
    debug: result % os.page_size = 0
  =>
    # NYI: UNDER DEVELOPMENT: document thoughts gone into choosing default buffer size
    os.page_size


  # default implementation of Buffer_Size
  #
  # this will get instated automatically at startup
  #
  public redef fixed type.default_value option io.Buffer_Size => io.Buffer_Size


# get the current buffer size from effect Buffer_Size
#
public type.buffer_size i64 ! io.Buffer_Size =>
  io.Buffer_Size.env.get
