# time.Wallclock -- effect providing access to system's main clock
#
# Note that this clock is non-monotonic, there might be jumps as for leap
# seconds or adjustments towards the future and the past.
#
#
public Wallclock ref : time.Clock is


  # This clock corresponds to POSIX 1003.1's CLOCK_REALTIME
  #
  public redef posix_id option posix.clockid_t
  =>
    posix.clock_realtime


  # no guarantee can be given for precision nor resolution
  #
  public redef read time.instant
  =>
    panic "NYI: time.Wallclock.read"


  # no guarantee can be given for precision nor resolution
  #
  public redef sleep(d time.duration) unit
  =>
    panic "NYI: time.Wallclock.sleep"


  # default implementation of time.Wallclock.
  #
  public redef fixed type.default_value option time.Wallclock
  =>
    time.Wallclock
