# time.monotonic -- effect providing access to system's monotonic clock
#
#
public Monotonic ref : posix_clock is


  # This clock corresponds to POSIX 1003.1's CLOCK_MONOONIC
  #
  public redef type.posix_id option posix.clockid_t
  =>
    posix.clock_monotonic


  # default implementation of time.Nano.
  #
  public redef fixed type.default_value option time.Monotonic
  =>
    time.Monotonic
