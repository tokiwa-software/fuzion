# envir.Args -- effect providing access to command line args
#
public Args ref : Sequence String, effect is


  # implement as_list
  #
  public redef as_list list String => abstract


  # default implementation of envir.Args
  #
  # this will get instated automatically at startup
  #
  public redef fixed type.default_value option envir.Args =>
    _ : envir.Args is
      public redef as_list list String =>
        # default uses fuzion.sys.args
        fuzion.sys.args.as_list
