# jitter -- demo measuring periodic task jitter using time.histogram
#
# See Makefile for how to start fuzion to run this example.
#
# NYI: UNDER DEVELOPMENT: Currently, this supports only one single test using
# `time.nano.run_periodic`.  Once we have support for periodic tasks run by dedicated
# threads, we should add jitter tests for those.
#
jitter_threaded =>

  # the period to start with
  #
  period_default => time.duration.ms  500


  # the time to spend with each period
  #
  test_duration  => time.duration.ms 2100


  # the time to wait before first release
  #
  start_delay    => time.duration.ms  500


  # should the linear histogram be output?
  #
  show_lin_histogram => true


  # should the log histogram be output?
  #
  show_log_histogram => true


  # should the linear csv be output?
  #
  show_lin_csv => false


  # should the log csv be output?
  #
  show_log_csv => false

  # Try to enable CPU affinity and optionally real-time scheduling.
  #
  enable_rt := true


  # run jitter test using C.clock.run_periodic
  # the worker streams raw per-release records to `sample_ch`; the caller groups
  # them into per-period tuples and builds histograms.
  # message format: (period, actual_release, expected_release, end_of_period_flag)
  test_jitter(# the clock used to schedule the releases
              C type : time.Clock,

              # the clock used to measure the times
              TIMER type : time.Clock,

              sample_ch concur.Channel (tuple time.duration time.instant i32))
  =>

      # type used to identify exception to stop in case jitter is too high
      jitter_too_high is

      # test payload, just some dummy code requiring a moderate amount of calculation
      payload =>
        for
          i := 0, i+1
          s := i, s +° i
        while i < 1000
        else
          if s = s +° 1   # make sure the compiler does not optimize this aways
            say "$s (never called)"

      # per-release callback will be defined inside run_for_period so it can
      # reference the current `period` value.

      # perform jitter test for given period: collect raw samples
      # Worker sends three kinds of messages to `sample_ch`:
      #  kind=0 -> start marker (period, start_time, 0)
      #  kind=1 -> actual release (period, actual_time, 1)
      #  kind=2 -> end marker (period, end_time, 2)
      run_for_period(period time.duration)
      =>

        start := C.env.read + start_delay
        end := start + test_duration

        # send start marker to receiver
        check sample_ch <- (period, start, 0)

        # run test; run_one_release will send raw records for every release
        # define per-release callback here so it can reference `period`
        run_one_release ! exception jitter_too_high =>
          actual_release := TIMER.env.read
          check sample_ch <- (period, actual_release, 1)
          payload

        _ := C.env.run_periodic start period end run_one_release

        # indicate end-of-period to receiver (use current time as marker)
        marker := TIMER.env.read
        check sample_ch <- (period, marker, 2)

        # run_one_release is expected to be defined elsewhere in this feature
        # and must send (period, actual_release, 1) for each release.

      _ := match exception jitter_too_high .on ()->

         for p := period_default, p.times 0.5
         while p.as_duration >= time.duration.ms 1 do
           run_for_period p

        _ error => unit
        unit    => unit

      unit

  say "Starting jitter test on dedicated thread..."
  result_ch := concur.Channel (tuple time.duration time.instant i32)
  thrd := concur.threads.env.spawn ()->
    test_jitter time.nano time.nano result_ch
    result_ch.close

  # affinity: pin the worker thread to CPU 0 (best-effort)
  match thrd.set_affinity ([0.as_u64].as_array)
    unit => say "Worker thread pinned to CPU 0"
    e error => say "Worker thread affinity setup failed: $e"

  # Attempt to set SCHED_FIFO.
  if enable_rt
    match thrd.set_policy(concur.scheduling_policy.sched_fifo, false, 99)
      unit => say "Worker thread configured for SCHED_FIFO priority 99"
      e error =>
        say "Worker thread priority setup failed: $e"
        say "(Hint: run with sudo or use setcap cap_sys_nice=ep ./jitter)"

  # collect streamed raw records from worker thread
  collect_results(received_ch concur.Channel (tuple time.duration time.instant i32),
                  collected list (tuple time.duration time.instant i32))
                  list (tuple time.duration time.instant i32)
  =>
    match received_ch.next
      sample tuple => collect_results received_ch (sample : collected)
      nil => collected.reverse_list

  # grouping accumulator type for folding raw records into per-period tuples
  grouping_acc(results list (tuple time.duration (list time.duration) (list time.duration)),
                cur_period option time.duration,
                start_time option time.instant,
                per_acc list time.duration,
                cyc_acc list time.duration,
                prev_actual option time.instant,
                count i32) is

  raw_records := collect_results result_ch nil

  # fold raw records into per-period tuples
  g0 := grouping_acc (list (tuple time.duration (list time.duration) (list time.duration))).empty nil nil (list time.duration).empty (list time.duration).empty nil 0

  g_final := raw_records.foldf _ g0 (g, rec ->
    period := rec.0
    ts := rec.1
    kind := rec.2

    if kind = 0 then
      # start marker: initialize accumulators and record start time
      grouping_acc g.results (option period) (option ts) (list time.duration).empty (list time.duration).empty nil 0
    else if kind = 1 then
      # actual release: compute expected from start_time + period*count
      match g.cur_period
        nil => g # stray actual before start - ignore
        p time.duration =>
          if p = period then
            start_t := g.start_time.or_panic
            expected := start_t + (period * g.count.as_u64)
            per_d := (ts >= expected ? ts - expected : expected - ts)
            cyc_acc2 := match g.prev_actual
                          nil => g.cyc_acc
                          prev time.instant => ( (ts >= prev ? ts - prev : prev - ts) : g.cyc_acc )
            per_acc2 := per_d : g.per_acc
            grouping_acc g.results (option p) g.start_time per_acc2 cyc_acc2 (option ts) (g.count + 1)
          else g
    else if kind = 2 then
      # end marker: finalize current period
      match g.cur_period
        nil => g
        p time.duration =>
          res := (p, g.per_acc, g.cyc_acc)
          grouping_acc (res : g.results) nil nil (list time.duration).empty (list time.duration).empty nil 0
    else g
  )

  received_samples := g_final.results.reverse_list
  say "received samples"
  for sample in received_samples do
    period, period_samples, cycle_samples := sample
    say "testing period $period for $test_duration..."
    h  := time.histogram.new "period jitter $period, log count / linear time" period period*2 1 0
    h2 := time.histogram.new "cycle jitter $period, log count / log time"     nil    nil      1 0
    for ps in period_samples
        cs in cycle_samples
    do
      h.add ps
      h2.add cs
    say "period jitter:"
    say "$h"
    say "cycle jitter:"
    say "$h2"
    if show_lin_csv then say "{h.csv}"
    if show_log_csv then say "{h2.csv}"
  say "Dedicated thread completed."

# How to run with high priority :
# FUZION_HOME=build bash bin/fz -c examples/jitter/jitter.fz
# sudo setcap cap_sys_nice=ep ./jitter
# ./jitter
