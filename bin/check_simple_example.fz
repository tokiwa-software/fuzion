########### Extensions ###############

is_windows =>
  os.platform.or_panic ? os.windows => true | os.posix => false

path_separator := is_windows ? ";" : ":"

# specified environment variables as key,value array
#
envir_var_kv := [
  "PATH",
  "LANG",
  "JAVA_HOME",
  "POSTCONDITIONS",
  "PRECONDITIONS",
  "dev_flang_tools_serializeFUIR",
  "dev_flang_fuir_analysis_dfa_DFA_MAX_ITERATIONS",
  "CPATH",
  "LIBRARY_PATH",
  "FUZION_CLANG_INSTALLED_DIR",
  "OS",
  "FUZION_HOME",
  "FUZION_JAVA",
  "FUZION_JAVA_STACK_SIZE",
  "FUZION_JAVA_OPTIONS",
  "FUZION_JVM_BACKEND_OPTIONS",
  "FUZION_C_BACKEND_OPTIONS",
  "FUZION_RANDOM_SEED",
  # set in simple.mk
  "LD_LIBRARY_PATH",
  "DYLD_FALLBACK_LIBRARY_PATH",
  "C_INCLUDE_PATH",
  "LANGUAGE",
  "dev_flang_fuir_analysis_dfa_TRACE_ALL_EFFECT_ENVS",
  # without this test/socket fails on windows,
  # winsock2 seems to need this to properly load the dlls
  "SYSTEMROOT",
  # next two are sometimes needed on windows
  "TEMP",
  "TMP",
  "SYSTEMROOT",
  "INFLUXDB_TOKEN"
].map k->
  if k="DYLD_FALLBACK_LIBRARY_PATH"||k="PATH"||k="LD_LIBRARY_PATH"
    envir.Vars.env[k]
      .bind v->(k,"$v$path_separator../../lib")
      .or_else (k,"../../lib")
  else
    envir.Vars.env[k].bind v->
      (k,v)
 .flat_map id
 .as_array

# envir vars as map
#
envir_vars :=
  (container.ordered_map
    (envir_var_kv
      .map (.0)
      .as_array)
    (envir_var_kv
      .map (.1)
      .as_array))
  .add "FUZION_DISABLE_ANSI_ESCAPES" "true"



############################################################################


# limit cpu time and stack size for executing test
cpu_time_limit   := time.duration.min 10  # NYI: UNDER DEVELOPMENT: we should decrease this value
stack_size_limit := units.data_size.b 1024 # NYI: UNDER DEVELOPMENT: stack limit is not yet set


# check exit code for validity
#
check_exit_code(run tokiwa.process_result) =>
  # 152 - 128 = 24 -> signal SIGXCPU
  if run.exit_code = 152
    say "$("*** CANCELLED:".bold.red) test $file exceeded cpu time limit of $cpu_time_limit s"
    Exit.env.exit 1
  # 139 - 128 = 11 -> signal SIGSEGV
  else if run.exit_code = 139
    say "$("*** CANCELLED:".bold.red) test $file exceeded stack size limit of $stack_size_limit"
    Exit.env.exit 1
  # pipe to head may result in exit code 141 -- broken pipe.
  else if run.exit_code != 0 && run.exit_code != 1 && run.exit_code != 141
    say "unexpected exit code $(run.exit_code)"
    Exit.env.exit 1


# clean error output from random names
# like loop4, preandcall19 etc.
#
clean_err(f path) =>

  if is_windows
    "sed -i s|/|#|g $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error
    # 8 slashes here intentional, unclear why so many are needed though...
    "sed -i s|\\\\\\\\|#|g $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error
    "sed -i s|$(os.cwd.or_panic.as_string.replace "\\" "#" .replace "/" "#")|--CURDIR--| $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error
    "sed -i s|$(("$(os.cwd.or_panic.as_string.substring 1 2):$(os.cwd.or_panic.as_string.substring 2)").replace "\\" "#" .replace "/" "#")|--CURDIR--| $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error
  _ := "sed -i s#$(os.cwd.or_panic.as_string)#--CURDIR--# $f".execute .or_panic
  # line numbers
  "sed -E -i s/\\.fz:[0-9]+:[0-9]+:/\\.fz:n:n:/g $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error
  "sed -E -i s/\\.(fz|java):[0-9]+/\\.\\1:n/g $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error
  # replace CLASS_PREFIX_WITH_ID
  "sed -E -i s/fzC__L[0-9]+/fzC_LXXX/g $f".execute envir_vars nil cpu_time_limit .or_panic.panic_on_error


# delete temporary files
#
delete_tmp_files =>
  _ := io.file.delete (path.of "tmp_out.txt")
  _ := io.file.delete (path.of "tmp_err.txt")
  _ := io.file.delete (path.of "testbin")
  _ := io.file.delete exp_err_cleaned


if envir.Args.env.count != 4
  say """
      Usage  : check_simple_example <jvm|c|int|effect> <fz+args> <test.fz>
      Example: check_simple_example jvm "build/bin/fz -modules=nom" tests/hello/HelloWorld.fz
      """
  Exit.env.exit 1


be     := envir.Args.env[1]
# can not execute bash script fz on windows with CreateProcess
fz_run := envir.Args.env[2].replace "../../bin/fz" "java $(is_windows ? "-Dsun.stdout.encoding=UTF-8 -Dsun.stderr.encoding=UTF-8" : "") --enable-preview --enable-native-access=ALL-UNNAMED --class-path ../../classes $(envir.Vars.env["FUZION_JAVA_OPTIONS"].or_else "") -Xss5m -Dline.separator=\n -Dfile.encoding=UTF-8 -Dfuzion.home=../../ -Dfuzion.command=fz dev.flang.tools.Fuzion"
file   := envir.Args.env[3]
input  := path.of "$file.stdin"
exp_out := if be = "effect"
             path.of "$file.effect"
           else
             if io.file.exists (path.of "$file.expected_out_$be") then (path.of "$file.expected_out_$be") else (path.of "$file.expected_out")
exp_err := if io.file.exists (path.of "$file.expected_err_$be") then (path.of "$file.expected_err_$be") else (path.of "$file.expected_err")
exp_err_cleaned := path.of "$exp_err.cleaned"

if io.file.exists (path.of "$file.skip") || (be = "effect" && !(io.file.exists (path.of "$file.effect")))
    say "SKIP $file"
else
    yap "RUN $file using $(be.pad_center 3) backend "

    delete_tmp_files


    # NYI: UNDER DEVELOPMENT:
    # setrlimit for executed processes
    # stack_size_limit, cpu_time_limit

    bt := concur.Threads.env.spawn ()->
      time.Nano.env.sleep cpu_time_limit
      say "$("*** CANCELLED:".bold.red) test $file exceeded cpu time limit of $cpu_time_limit"
      Exit.env.exit 1

    concur.Threads.env.detach bt

    backend_options(x) =>
      s := envir.Vars.env
                .get x
                .or_default ""
                .replace " " tokiwa.protected_space
                .split "|"
      String.join s " "

    if be = "c"
      compile := "$fz_run -XmaxErrors=-1 -c $(backend_options "FUZION_C_BACKEND_OPTIONS") $file -o=testbin".execute envir_vars nil cpu_time_limit .or_panic
      if compile.ok
        run := "./testbin".execute envir_vars input cpu_time_limit .or_panic

        check_exit_code run

        io.write (path.of "tmp_out.txt") run.out .or_panic
        io.write (path.of "tmp_err.txt") run.err .or_panic
      else
        io.write (path.of "tmp_out.txt") compile.out .or_panic
        io.write (path.of "tmp_err.txt") compile.err .or_panic
    else if be = "jvm"
      run := "$fz_run -XmaxErrors=-1 -jvm $(backend_options "FUZION_JVM_BACKEND_OPTIONS") $file".execute envir_vars input cpu_time_limit .or_panic

      check_exit_code run

      io.write (path.of "tmp_out.txt") run.out .or_panic
      io.write (path.of "tmp_err.txt") run.err .or_panic
    else if be = "int"
      run := "$fz_run -XmaxErrors=-1 -interpreter $file".execute envir_vars input cpu_time_limit .or_panic

      check_exit_code run

      io.write (path.of "tmp_out.txt") run.out .or_panic
      io.write (path.of "tmp_err.txt") run.err .or_panic
    else if be = "effect"
      run := "$fz_run -XmaxErrors=-1 -effects $file".execute envir_vars nil cpu_time_limit .or_panic

      check_exit_code run

      io.write (path.of "tmp_out.txt") ((run.out.lines.filter (l -> !l.is_empty)).sort.as_string "\n")+"\n" .or_panic
    else
      panic "backend unknown: $be"

    out := "diff --strip-trailing-cr $(exp_out) tmp_out.txt".execute envir_vars nil cpu_time_limit .or_panic

    err :=
      if be != "effect"
        io.copy exp_err exp_err_cleaned .or_panic
        clean_err (path.of "tmp_err.txt")
        clean_err exp_err_cleaned
        "diff --strip-trailing-cr $(exp_err_cleaned) tmp_err.txt".execute envir_vars nil cpu_time_limit .or_panic
      else
        tokiwa.process_result.empty_success

    delete_tmp_files

    if !out.ok
      say "$("*** FAILED".bold.red) out on $file"
      say out.out
    if !err.ok
      say "$("*** FAILED".bold.red) err on $file"
      say err.out

    if out.ok && err.ok
      say "$("PASSED".bold.green)."
    else
      Exit.env.exit 1
