# NYI: UNDER DEVELOPMENT: define common benchmark interface, refactor to use this
read_10mb_file =>

  read_file(file io.path) outcome (array u8) =>
    io.file.use file io.file.mode.append ()->
      sz := (io.file.stat file false).or_panic.size
      io.file.open.mmap 0 sz.bytes.as_i64 ()->
        array u8 _ sz.bytes i->
          io.file.mapped_buffer.env[i.as_i64]

  read_file2(file io.path) outcome (Sequence u8) =>
    io.file.use file io.file.mode.read ()->
      (io.buffered io.file.file_mutate).read_fully

  f := io.path.of "/tmp/file"

  a := array u8 _ 1E7 _->65
  s := _ : String is
         public redef utf8 Sequence u8 => a

  io.file.write f s .or_panic

  say <| io.file.Stat.env.stats f

  test(arg io.path) =>
    say "mmap: $arg iterations/s"
    say <| bench
      (time.duration.s 1)
      (time.duration.s 10)
      (()->
       check read_file (io.path.of "$arg") .or_panic.count=1E7
        )
    say "stdlib: $arg iterations/s"
    say <| bench
      (time.duration.s 1)
      (time.duration.s 10)
      (()->
       check read_file2 arg .or_panic.count=1E7
        )

  test f

  io.file.delete f .or_panic
